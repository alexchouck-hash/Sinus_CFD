FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      controlDict;
}

application     simpleFoam;

startFrom       startTime;
startTime       0;
stopAt          endTime;
// Stable re-solve on watertight airway mesh (~71 mL)
endTime         500;
deltaT          1;
writeControl    timeStep;
writeInterval   50;
purgeWrite      6;
writeFormat     ascii;
writePrecision  8;
writeCompression off;
timeFormat      general;
timePrecision   6;
runTimeModifiable true;

functions
{
}
